# ====================================
# Codice Civile Sistematico AI — Configurazione
# ====================================

# Scegli uno dei due provider LLM:
ANTHROPIC_API_KEY=sk-ant-...
# oppure
OPENAI_API_KEY=sk-...

# Provider attivo: "anthropic" o "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# Path al PDF (relativo alla root del progetto)
PDF_PATH=./data/Codice-civile-Sistematico.pdf

# Dimensione chunk in caratteri
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# Numero di chunk da recuperare per query
TOP_K=8

# SICUREZZA
# Il server risponde SOLO su localhost (non modificare)
HOST=127.0.0.1
PORT=8000

# Timeout in secondi per le chiamate al LLM
LLM_TIMEOUT=30

# Max query al minuto per IP
RATE_LIMIT_PER_MINUTE=20

# Max lunghezza query in caratteri
MAX_QUERY_LENGTH=1000
